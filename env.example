# .env — MeshCore platform secrets.  Keep out of version control.

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Europe/Zurich

# ── MySQL ─────────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_NAME=meshcore
DB_USER=
DB_PORT=3306
DB_PASSWORD=

# ── MQTT Broker – TLS (used by get_meshcore_from_mqtt.py) ────────────────────
MQTT_SERVER=mqtt.alfare.net
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PACKETS=meshcore/+/+/packets

# ── Additional hash-derived channels ──────────────────────────────────────────
# Array of channel names (must start with #). Single or double quotes both work.
# These are added on top of the built-in HASH_CHANNELS list in the script.
EXTRA_HASH_CHANNELS=[]

# ── MeshCore channel secrets (static / pre-shared key channels) ───────────────
# JSON object mapping channel-name → 128-bit hex secret (32 hex chars each).
# Add new channels here; they are picked up on the next restart.
STATIC_CHANNELS={"public":"8b3387e9c5cdea6ac9e5edbaa115cd72","italia":"4c97bfe431abe20672259d9b6969dcec","Ticino":"1a9ff7fa3a1b44b977ebec94a4bbefa9","Piemonte":"5b9baef4c3d8751e2f9292f0b9f7b6a6","Varazze":"c2d3303da56ae5d4086a74420f25183b"}
